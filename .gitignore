# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/test-results/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
**/.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*.pem

# Cursor local (ignore direct children; allow rules/ and skills/ directories through)
.cursor/*
!.cursor/rules/
!.cursor/skills/

# Claude local (skills moved to .cursor/skills/)
.claude/

# Editor local settings (personal, not for repo)
# To share recommended extensions, un-ignore .vscode/extensions.json
.vscode/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (do not commit secrets; example file is tracked)
.env
.env.*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# personal notes (local only — do not commit). 对外简明用户说明见 docs/notes/
/notes/
