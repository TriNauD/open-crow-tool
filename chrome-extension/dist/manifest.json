{
  "manifest_version": 3,
  "name": "这他妈是啥？",
  "version": "0.1.0",
  "description": "划词即解释，AI 大白话，一键存入笔记本",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "commands": {
    "explain-selection": {
      "suggested_key": {
        "default": "Alt+W",
        "mac": "MacCtrl+Shift+W"
      },
      "description": "解释选中文字"
    }
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.tsx-loader-kPCHIXoY.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "这他妈是啥？"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/client-Cmjl_fXq.js",
        "assets/index.tsx-DeCSUkAh.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
