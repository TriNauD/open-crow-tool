{
  "name": "open-crow-tool",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.20.2",
    "npm": "10.8.2"
  },
  "scripts": {
    "dev": "npx -y node@20 node_modules/next/dist/bin/next dev",
    "dev:lan": "node scripts/dev-lan.mjs",
    "build": "npx -y node@20 node_modules/next/dist/bin/next build",
    "start": "npx -y node@20 node_modules/next/dist/bin/next start",
    "lint": "npx -y node@20 node_modules/eslint/bin/eslint.js . chrome-extension/src e2e",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:full": "npm run build && npm run test:e2e",
    "verify": "node scripts/verify.mjs",
    "verify:e2e": "VERIFY_E2E=1 node scripts/verify.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1",
    "@types/nodemailer": "^8.0.0",
    "cheerio": "^1.2.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "nodemailer": "^8.0.6",
    "openai": "^6.34.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
