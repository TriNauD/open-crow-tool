# ============================================================
# 环境变量配置
# 复制为 .env.local，填入你自己的 key
# 分环境说明见 docs/tech/environments-and-deployment.md
# ============================================================

# ---------- AI Provider ----------
# 主 provider：openai / siliconflow / nvidia（默认 siliconflow）
# 失败时自动 fallback，顺序：siliconflow → nvidia（只 fallback 有 key 的）
AI_PROVIDER=siliconflow

# 主 provider 的 API Key
AI_API_KEY=sk-...

# 模型名（不填则用 provider 默认值）
# 硅基流动: deepseek-ai/DeepSeek-V4-Flash | OpenAI: gpt-4o | NVIDIA: meta/llama-3.3-70b-instruct
AI_MODEL=deepseek-ai/DeepSeek-V4-Flash

# 可选：覆盖主 provider 的 base URL（一般不填）
# AI_BASE_URL=https://api.siliconflow.cn/v1

# --- 备用 provider keys（有 key 才会加入 fallback 链）---
SILICONFLOW_API_KEY=sk-...
NVIDIA_API_KEY=nvapi-...

# 可选：各备用 provider 的 model / base URL 覆盖
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ---------- Supabase ----------
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# 公开站点根 URL（无尾斜杠；与 Vercel 生产域名对齐）
# NEXT_PUBLIC_SITE_URL=https://your.domain.com

# Notebook 多用户开关（默认开启）
NOTEBOOK_MULTI_USER_ENABLED=true

# ---------- 周报邮件 ----------
# 真实订阅者开关（⚠️ 必须填完整字符串 SEND_TO_SUBSCRIBERS 才会群发）
# 本地开发保持注释；Vercel 生产确认稳定后填入
# SUBSCRIBER_SEND_ENABLED=SEND_TO_SUBSCRIBERS

# 发信服务（填了 SMTP 就走 SMTP，否则走 Resend）
RESEND_API_KEY=re_...
RESEND_FROM=onboarding@resend.dev
RESEND_FROM_NAME=OpenCrow
# SMTP_USER=hang-le-ma@outlook.com
# SMTP_PASS=你的密码或应用密码

# 内部测试收件人（始终发送，不受开关影响）
DIGEST_TEST_EMAILS=you@example.com,you2@example.com

# Cron 运维通知（留空不发送；逗号分隔多个）
# DIGEST_OPS_NOTIFY_EMAILS=you@example.com
# 设为 true 时：仅当「完成发信循环后的汇总」里存在发信失败才发该汇总；全成功则不打扰（抓取/空 Trending 等**中止**通知仍会发送）
# DIGEST_OPS_NOTIFY_ONLY_ON_FAILURE=false

# Cron 鉴权 secret（建议 openssl rand -hex 16 生成）
CRON_SECRET=your-cron-secret-here

# 可选：按编程语言过滤 GitHub Trending（逗号分隔，空则不过滤）
# DIGEST_LANGUAGE_FILTER=
