# ============================================================
# 这他妈是啥？ — 环境变量配置
# 复制这个文件为 .env.local，填入你自己的 key
# ============================================================

# AI Provider: openai / deepseek / siliconflow
AI_PROVIDER=siliconflow

# 通用 API Key（三个 provider 都用这个，优先级最高）
AI_API_KEY=sk-...

# 通用模型名（不填则使用 provider 的默认值）
# 硅基流动：deepseek-ai/DeepSeek-V3 / deepseek-ai/DeepSeek-R1 / Qwen/Qwen2.5-72B-Instruct
# DeepSeek：deepseek-chat / deepseek-reasoner
# OpenAI：gpt-4o / gpt-4o-mini
AI_MODEL=deepseek-ai/DeepSeek-V3

# 可选：覆盖 provider 的 base URL（一般不需要填）
# AI_BASE_URL=https://api.siliconflow.cn/v1

# ============================================================
# 以下是 Phase 3 周报功能需要的，MVP 阶段可以先不填
# ============================================================

# Resend API Key (邮件推送用)
# 去 https://resend.com/api-keys 获取
RESEND_API_KEY=re_...

# 周报发送的发件人地址（需要在 Resend 验证域名）
RESEND_FROM=wtf@yourdomain.com

# Supabase (如果以后要做云端同步笔记本)
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
