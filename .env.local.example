# ============================================================
# 这他妈是啥？ — 环境变量配置
# 复制这个文件为 .env.local，填入你自己的 key
# ============================================================

# AI Provider: openai / siliconflow / nvidia
AI_PROVIDER=siliconflow

# 通用 API Key（主 provider 用；nvidia 主用时也可填这里）
AI_API_KEY=sk-...

# 通用模型名（不填则使用 provider 的默认值）
# 硅基流动：deepseek-ai/DeepSeek-V3 / deepseek-ai/DeepSeek-R1 / Qwen/Qwen2.5-72B-Instruct
# OpenAI：gpt-4o / gpt-4o-mini
# 英伟达 NIM：meta/llama-3.3-70b-instruct / deepseek-ai/deepseek-r1 等（以控制台为准）
AI_MODEL=deepseek-ai/DeepSeek-V3

# 可选：覆盖主 provider 的 base URL（一般不需要填）
# AI_BASE_URL=https://api.siliconflow.cn/v1

# ---------- 英伟达 NVIDIA（build.nvidia.com 申请的 nvapi-... key）----------
# 单独作主线路由：AI_PROVIDER=nvidia，并填下面 key（或把 key 写在 AI_API_KEY）
NVIDIA_API_KEY=nvapi-...
# 可选：默认 meta/llama-3.3-70b-instruct
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# 可选：自建/代理 NIM 时改 base（默认 integrate.api.nvidia.com）
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# 主线路由失败时，自动改用英伟达再试一次（需同时有 NVIDIA_API_KEY）
AI_ENABLE_NVIDIA_FALLBACK=true

# ============================================================
# Phase 1 — Supabase 数据库 + 鉴权（笔记本云端同步必填）
# ============================================================

# Supabase 项目地址（supabase.com → 项目 Settings → API）
SUPABASE_URL=https://xxxx.supabase.co

# Service Role Key（后端专用，绝对不要暴露给前端）
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# 鉴权 secret（Chrome 插件用，建议 openssl rand -hex 16 生成）
ADMIN_SECRET=your-random-secret-here

# 固定用户 ID（所有笔记归属到这个 UUID，运行 crypto.randomUUID() 生成一次后写死）
ADMIN_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ============================================================
# Phase 3 — 周报邮件（暂不需要填）
# ============================================================

# Resend API Key（https://resend.com/api-keys 获取）
# RESEND_API_KEY=re_...

# 周报收件邮箱
# DIGEST_TO_EMAIL=you@example.com

# 周报发件人（需在 Resend 验证域名，或用 onboarding@resend.dev 测试）
# RESEND_FROM=wtf@yourdomain.com

# 可选：按编程语言过滤 GitHub Trending（如 "TypeScript,Python"，空则不过滤）
# DIGEST_LANGUAGE_FILTER=
