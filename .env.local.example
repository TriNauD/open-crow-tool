# ============================================================
# 这是啥？ — 环境变量配置
# 复制这个文件为 .env.local，填入你自己的 key
#
# 分环境（本地 / Vercel Preview / 生产）与常见坑见：docs/tech/environments-and-deployment.md
# ============================================================

# AI Provider: openai / siliconflow / nvidia
AI_PROVIDER=siliconflow

# 通用 API Key（主 provider 用；nvidia 主用时也可填这里）
AI_API_KEY=sk-...

# 通用模型名（不填则使用 provider 的默认值）
# 硅基流动：deepseek-ai/DeepSeek-V3 / deepseek-ai/DeepSeek-R1 / Qwen/Qwen2.5-72B-Instruct
# OpenAI：gpt-4o / gpt-4o-mini
# 英伟达 NIM：meta/llama-3.3-70b-instruct / deepseek-ai/deepseek-r1 等（以控制台为准）
AI_MODEL=deepseek-ai/DeepSeek-V3

# 可选：覆盖主 provider 的 base URL（一般不需要填）
# AI_BASE_URL=https://api.siliconflow.cn/v1

# ---------- 英伟达 NVIDIA（build.nvidia.com 申请的 nvapi-... key）----------
# 单独作主线路由：AI_PROVIDER=nvidia，并填下面 key（或把 key 写在 AI_API_KEY）
NVIDIA_API_KEY=nvapi-...
# 可选：默认 meta/llama-3.3-70b-instruct
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# 可选：自建/代理 NIM 时改 base（默认 integrate.api.nvidia.com）
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# 主线路由失败时，自动改用英伟达再试一次（需同时有 NVIDIA_API_KEY）
AI_ENABLE_NVIDIA_FALLBACK=true

# ============================================================
# Phase 1 — Supabase 数据库 + 鉴权（笔记本云端同步必填）
# ============================================================

# Supabase 项目地址（supabase.com → 项目 Settings → API）
SUPABASE_URL=https://xxxx.supabase.co

# Service Role Key（后端专用，绝对不要暴露给前端）
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Public anon key（前端登录 + 用户态请求需要）
SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ---------- Chrome 扩展（Vite 打包）可选：与上两项同值 ----------
# 扩展目录 `chrome-extension/.env` 中写入 `VITE_PUBLIC_SUPABASE_URL` / `VITE_PUBLIC_SUPABASE_ANON_KEY`，
# 划词保存前 refresh 会话时可在 storage 缺省时补齐 Supabase 项目配置。见 `chrome-extension/.env.example`。

# 公开站点根 URL（无尾斜杠）。用于少数需「非浏览器上下文」场景的备用；用户在网页上注册/确认邮箱时仍以当前浏览器域名为准。
# 生产环境与 Vercel 生产域名对齐；不要将本地 http://localhost:3000 填到生产的 Vercel 环境变量。
# Supabase Dashboard → Authentication → Site URL / Redirect URLs 也应配置生产地址，见 lib/auth/email-confirm-redirect.ts。
# NEXT_PUBLIC_SITE_URL=https://your.domain.com

# Notebook 多用户开关（默认开启；设为 false 可快速关闭）
NOTEBOOK_MULTI_USER_ENABLED=true

# ============================================================
# Phase 4 — 外部订阅（subscribers 表）
# 无新增环境变量。在 Supabase SQL Editor 执行以下 DDL 建表：
#
# create table subscribers (
#   id                     uuid primary key default gen_random_uuid(),
#   email                  text unique not null,
#   status                 text default 'active',
#   stripe_customer_id     text,
#   stripe_subscription_id text,
#   unsubscribe_token      uuid default gen_random_uuid(),
#   subscribed_at          timestamptz default now(),
#   cancelled_at           timestamptz
# );
# create index subscribers_status_idx on subscribers(status);
# create index subscribers_unsubscribe_token_idx on subscribers(unsubscribe_token);
# ============================================================

# ============================================================
# Phase 3 — 周报邮件
# ============================================================

# Resend API Key（https://resend.com/api-keys 获取）
RESEND_API_KEY=re_...

# 【Cron 运维通知】每周周报任务跑完后（或抓取阶段失败）发一封汇总到你的邮箱
# 逗号分隔多个；留空则不发送运维邮件
# DIGEST_OPS_NOTIFY_EMAILS=you@example.com
# 设为 true 时：仅当「完成发信循环后的汇总」里存在发信失败才发该汇总；全成功则不打扰（抓取/空 Trending 等**中止**通知仍会发送）
# DIGEST_OPS_NOTIFY_ONLY_ON_FAILURE=false

# 【内部测试收件人】始终发送，不受任何开关影响
# 填你自己的邮箱，可逗号分隔多个，和真实用户完全隔离
DIGEST_TEST_EMAILS=you@example.com,you2@example.com

# 旧版单一管理员邮箱（已废弃，由 DIGEST_TEST_EMAILS 替代，保留作 fallback）
# DIGEST_TO_EMAIL=you@example.com

# 【真实订阅者开关】⚠️ 防误触设计 ⚠️
# 必须填写完整字符串 SEND_TO_SUBSCRIBERS 才会群发给 DB 里的 active 订阅者
# 本地开发：保持注释，DB 订阅者不会收到邮件
# Vercel 生产：确认稳定后在 Settings > Environment Variables 里填入
# SUBSCRIBER_SEND_ENABLED=SEND_TO_SUBSCRIBERS

# 周报发件人
# 测试阶段可用 Resend 默认发件人 onboarding@resend.dev（无需验证域名）
# 正式使用需在 Resend 验证自己的域名
RESEND_FROM=onboarding@resend.dev
# 发件人显示名称（邮件客户端里显示在发件人位置）
RESEND_FROM_NAME=Crow's Pick

# ---------- SMTP 发信（可选，不需要买域名）----------
# 填了 SMTP_USER + SMTP_PASS 就会优先用 SMTP 发，忽略 Resend
# 支持 Gmail（@gmail.com）和 Outlook（@outlook.com / @hotmail.com）
# Gmail App Password：myaccount.google.com/security → 两步验证 → App passwords
# Outlook App Password：account.microsoft.com/security → 高级安全选项 → 应用密码
SMTP_USER=hang-le-ma@outlook.com
SMTP_PASS=你的密码或应用密码

# Cron 鉴权 secret（建议 openssl rand -hex 16 生成，同时配置到 Vercel 环境变量）
# 本地手动测试时在请求 header 带 Authorization: Bearer <此值>
CRON_SECRET=your-cron-secret-here

# 可选：按编程语言过滤 GitHub Trending（逗号分隔，如 "TypeScript,Python"，空则不过滤）
# DIGEST_LANGUAGE_FILTER=
